generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Appointment {
  id            String   @id @default(cuid())
  date          String
  time          String
  sessionType   String
  patientName   String
  patientEmail  String
  patientPhone  String
  patientAge    String?
  notes         String?
  status        String   @default("pending") // pending, confirmed, cancelled
  paymentStatus String   @default("pending") // pending, paid
  paymentId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
